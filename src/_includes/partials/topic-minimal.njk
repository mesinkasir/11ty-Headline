<section class="gh-topic gh-topic-minimal">
    <header class="gh-topic-header">
        <h2 class="gh-topic-name">
            <a href="/tag/{{ topic.name | slug }}/">{{ topic.name }}</a>
        </h2>
        <a class="gh-topic-link" href="/tag/{{ topic.name | slug }}/">{{ "More" | t }}<span class="gh-sr-only"> {{ topic.name }}</span> {% include "partials/icons/arrow.njk" %}</a>
    </header>

    <div class="gh-topic-content">
        {% for post in (collections.posts | byTag(topic.name) | head(5)) %}
            {% include "partials/loop-minimal.njk" %}
        {% endfor %}
    </div>
</section>
