<article class="gh-card{% if large %} large{% endif %}{% if isLCP and isHome %} hero{% endif %} h-entry" itemscope itemtype="https://schema.org/BlogPosting">
    <a class="gh-card-link u-url" itemprop="url" href="{{ post.url }}">
        {% if post.data.feature_image %}
            <figure class="gh-card-image">
                <img
                    src="{{ post.data.feature_image }}"
                    alt="{{ post.data.feature_image_alt or post.data.title }}"
                    sizes="{% if isLCP and isHome %}100vw{% else %}(min-width: 768px) 160px, 120px{% endif %}"
                    {% if isLCP %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
                    decoding="async"
                >
            </figure>
        {% endif %}

        <div class="gh-card-wrapper">
            <header class="gh-card-header">
                <h2 class="gh-card-title p-name" itemprop="headline">{{ post.data.title }}</h2>
            </header>

            {% if large or not isHome %}
                {% set cardExcerpt = post.data.custom_excerpt or (post.content | excerpt(40)) %}
                {% if cardExcerpt %}
                    <div class="gh-card-excerpt">{{ cardExcerpt }}</div>
                {% endif %}
            {% endif %}

            <footer class="gh-card-footer">
              <span class="gh-card-tags">
    {% for tag in post.data.tags %}
        {% if tag != "posts" %}
            {{ tag }}{% if not loop.last %}, {% endif %}
        {% endif %}
    {% endfor %}
</span>

                <span class="gh-card-author">{% for a in (post.data.authors | resolveAuthors(authors)) %}{% if loop.first %}{{ a.name }}{% else %}, {{ a.name }}{% endif %}{% endfor %}</span>
                <time class="gh-card-date dt-published" itemprop="datePublished" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate('dd LLL yyyy') }}</time>
            </footer>
        </div>
    </a>
</article>