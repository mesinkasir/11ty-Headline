{
  "name": "11ty-headline",
  "version": "1.0.0",
  "description": "Headline — the Ghost local-news theme, converted to Eleventy (v4) with Nunjucks, Pagefind search, light/dark mode and Pages CMS. Originally a Ghost theme by Ghost Foundation; 11ty conversion by Adam DJ Brett.",
  "type": "module",
  "scripts": {
    "dev": "npx @11ty/eleventy --serve --quiet",
    "start": "npx @11ty/eleventy --serve --quiet",
    "build": "npx @11ty/eleventy",
    "serve": "npx @11ty/eleventy --serve",
    "debug": "cross-env DEBUG=Eleventy* npx @11ty/eleventy",
    "clean": "rm -rf _site"
  },
  "keywords": [
    "eleventy",
    "11ty",
    "nunjucks",
    "ghost-theme",
    "headline",
    "pagefind",
    "pagescms"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/adamdjbrett/11ty-Headline.git"
  },
  "author": {
    "name": "Adam DJ Brett",
    "email": "info@adamdjbrett.com",
    "url": "https://adamdjbrett.com/"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@11ty/eleventy": "4.0.0-alpha.10",
    "@11ty/eleventy-img": "^6.0.4",
    "@awesome.me/buildawesome": "^4.0.0-alpha.10",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "js-yaml": "^4.1.0",
    "luxon": "^3.7.2",
    "pagefind": "^1.4.0",
    "turndown": "^7.2.4"
  },
  "allowScripts": {
    "sharp@0.33.5": true
  }
}
